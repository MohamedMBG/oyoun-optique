# ============================================================
# SECURITY CHECKLIST (CRIT-1 fix)
# ============================================================
# 1. Never commit .env — only commit .env.example (this file)
# 2. Generate NEXTAUTH_SECRET with:
#      openssl rand -base64 64
# 3. Set ALLOWED_ORIGIN to your production domain in Vercel →
#    Settings → Environment Variables
# 4. Configure Upstash Redis (required in production):
#    https://console.upstash.com/
# ============================================================

# Database (Supabase / PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://your-production-domain.com"
# Generate with: openssl rand -base64 64
NEXTAUTH_SECRET="<generate-with-openssl-rand-base64-64>"

# CORS — set to your production domain (no trailing slash)
ALLOWED_ORIGIN="https://your-production-domain.com"

# Email (SMTP / Resend)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="your-gmail@gmail.com"
# Use a Gmail App Password (not your account password):
# https://myaccount.google.com/apppasswords
SMTP_PASS="<gmail-app-password>"
FROM_EMAIL="your-gmail@gmail.com"
FROM_NAME="O'YOUN Optique"

# Upstash Redis — REQUIRED in production for persistent rate limiting
# https://console.upstash.com/
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<your-upstash-token>"
